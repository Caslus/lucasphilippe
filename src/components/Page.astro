---
import Base from "../components/Base.astro";
import LanguagePicker from "../components/LanguagePicker.astro";
import Scribble from "../components/Scribble.astro";
import HeroPhoto from "../components/HeroPhoto.astro";

import { getLangFromUrl, useTranslation } from "../i18n/utils";
import type { UIStrings } from "../interfaces/i18n";

import { url, github, linkedin } from "../config/config";
import Social from "./Social.astro";

const lang = getLangFromUrl(Astro.url);
const translation = useTranslation(lang as keyof UIStrings);
---

<Base>
	<LanguagePicker />
	<wrapper
		class="flex justify-center items-center flex-row h-dvh gap-12 max-md:flex-col"
	>
		<div class="w-[25rem] max-sm:w-11/12">
			<code class="text-content-dark text-xs"
				>👋 {translation("greeting")}</code
			>
			<h1 class="text-title-dark m-0 font-bold text-3xl">
				{translation("name")}
			</h1>
			<p class="text-content-dark mt-3 leading-tight">
				{translation("description")}
			</p>
			<p class="text-content-dark mt-3">📍 {translation("location")}</p>
			<links class="flex flex-wrap flex-row gap-4 mt-3 max-2xsm:flex-col">
				<Social href={github} icon="github" text="github" />
				<Social href={linkedin} icon="linkedin" text="linkedin" />
				<Social
					href={`${url}/${translation("resumeFile")}`}
					icon="resume"
					text="resume"
				/>
			</links>
		</div>
		<HeroPhoto src={`${url}/lucas.webp`} alt={translation("image") ?? ""} />
	</wrapper>
	<background
		class="fixed top-1/2 left-1/2 -z-10 text-primary w-[60rem] origin-center -translate-x-1/2 -translate-y-1/2 scale-100 max-[900px]:scale-[0.88] max-[700px]:scale-[0.8] max-[520px]:scale-[0.72] max-[420px]:scale-[0.64]"
	>
		<Scribble />
	</background>
</Base>
